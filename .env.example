XAI_API_KEY=

# Instruction loading (choose one)
XAI_INSTRUCTIONS="You are a helpful assistant that can answer questions and help with tasks."
#XAI_URL_INSTRUCTIONS="https://your-api.com/instructions"
#XAI_FILE_INSTRUCTIONS="./instructions.txt"

